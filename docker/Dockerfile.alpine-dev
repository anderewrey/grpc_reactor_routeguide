# syntax=docker/dockerfile:1
# Full project build using Alpine's native packages (no vcpkg).
# Build from the repo root:
#   docker build -f docker/Dockerfile.alpine-dev -t rg-alpine-dev .
#   docker run --rm rg-alpine-dev

FROM alpine:3.24

RUN apk add --no-cache \
    cmake ninja g++ git \
    protobuf-dev \
    grpc-dev \
    abseil-cpp-dev \
    c-ares-dev \
    re2-dev \
    openssl-dev \
    zlib-dev \
    spdlog-dev \
    gflags-dev \
    gtest-dev \
    glaze

# EventLoop isn't packaged anywhere. This reproduces what the custom vcpkg
# port does (same pinned commit, same CMake install rules added by its patch)
# but appends the rules directly instead of using `git apply`, which fails
# with an overly strict context-match error on this commit.
RUN <<'EOF'
git clone https://github.com/amoldhamale1105/EventLoop.git /tmp/EventLoop
cd /tmp/EventLoop
git checkout e16fa52aae1d58a994fd93808c62fde14adb62f1
cat >> CMakeLists.txt <<'CMAKE_EOF'

# Install library
install(TARGETS ${PROJECT_NAME}
    EXPORT EventLoopTargets
    LIBRARY DESTINATION lib
    ARCHIVE DESTINATION lib
    RUNTIME DESTINATION bin
    INCLUDES DESTINATION include
)

# Install headers
install(FILES ${INCLUDES}
    DESTINATION include
)

# Install CMake config files
install(EXPORT EventLoopTargets
    FILE EventLoopConfig.cmake
    NAMESPACE EventLoop::
    DESTINATION lib/cmake/EventLoop
)
CMAKE_EOF
cmake -B build -GNinja -DCMAKE_BUILD_TYPE=Release -DCMAKE_POLICY_VERSION_MINIMUM=3.5
cmake --build build
cmake --install build
rm -rf /tmp/EventLoop
EOF

WORKDIR /src
COPY . .

RUN cmake -B build -GNinja -DCMAKE_BUILD_TYPE=Debug \
    && cmake --build build \
    && ctest --test-dir build --output-on-failure
